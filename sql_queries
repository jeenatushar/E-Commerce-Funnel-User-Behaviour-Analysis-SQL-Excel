USE sales;

select  *  from user_events;
describe user_events;
with summary as (SELECT event_type,count(distinct(user_id)) as total FROM user_events group by event_type order by total desc)
select *,  CASE 
        WHEN event_type = 'page_view' THEN 'page_view → add_to_cart'
        WHEN event_type = 'add_to_cart' THEN 'add_to_cart → checkout_start'
        WHEN event_type = 'checkout_start' THEN 'checkout_start → payment_info'
        WHEN event_type = 'payment_info' THEN 'payment_info → purchase'
        ELSE 'final step'
    END AS step_flow, CASE 
        WHEN event_type = 'page_view' THEN 
            (total - (SELECT total FROM summary WHERE event_type = 'add_to_cart')) * 100.0 / total

        WHEN event_type = 'add_to_cart' THEN 
            (total - (SELECT total FROM summary WHERE event_type = 'checkout_start')) * 100.0 / total

        WHEN event_type = 'checkout_start' THEN 
            (total - (SELECT total FROM summary WHERE event_type = 'payment_info')) * 100.0 / total

        WHEN event_type = 'payment_info' THEN 
            (total - (SELECT total FROM summary WHERE event_type = 'purchase')) * 100.0 / total

        ELSE 0
    END AS percentage_drop from summary;



2.USE sales;
/*Email:
View = 522
Add to Cart = 326
Conversion = 326 / 522 × 100 ≈ 62%

 Meaning:

62% of users who viewed added to cart
This is good conversion
 Simple Real-Life Meaning

Think of a shop:

100 people enter store (views)
40 pick items (add to cart)

Conversion = 40%
*/
with te as( select traffic_source, count( distinct case when event_type='page_view' then user_id end ) as view,
count( distinct case when event_type='add_to_cart' then user_id end ) as add_to_cart,
count( distinct case when event_type='checkout_start' then user_id end ) as checkout_start,
count( distinct case when event_type='payment_info' then user_id end ) as payment_info,
count( distinct case when event_type='purchase' then user_id end ) as purchase  from user_events
group by traffic_source)
select *, ROUND(add_to_cart * 100.0 / view) AS Conversion_Rate_view_to_Cart,
    ROUND(checkout_start * 100.0 / add_to_cart) AS Conversion_Rate_Cart_to_checkout_start,
    ROUND(payment_info * 100.0 / checkout_start) AS Conversion_Rate_Checkout_start_to_Payment_info,
    ROUND(purchase * 100.0 / payment_info) AS Conversion_Rate_payment_info_to_purchase from te;



3.select traffic_source,SUM(amount) as revenue,ROW_NUMBER() OVER (ORDER BY SUM(amount) DESC) AS ranking from user_events group by traffic_source order by revenue desc;
